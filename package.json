{
  "name": "cesium-friendly-plugin",
  "version": "2.0.0",
  "description": "A friendly Cesium plugin with chainable API, geometry, materials, data loading, and Vue integration",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "browser": "dist/index.umd.js",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./vue": {
      "import": "./dist/vue.esm.js",
      "require": "./dist/vue.js",
      "default": "./dist/vue.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && rollup -c --bundleConfigAsCjs",
    "dev": "rollup -c -w --bundleConfigAsCjs",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "cesium",
    "3d",
    "globe",
    "map",
    "plugin",
    "vue",
    "visualization"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mdzz-debug/cesium-friendly-plugin.git"
  },
  "bugs": {
    "url": "https://github.com/mdzz-debug/cesium-friendly-plugin/issues"
  },
  "homepage": "http://cf.luohao.online/",
  "peerDependencies": {
    "cesium": "^1.100.0",
    "vue": "^2.0.0 || ^3.0.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.0",
    "@rollup/plugin-node-resolve": "^15.0.0",
    "rollup": "^3.0.0",
    "rollup-plugin-terser": "^7.0.0"
  },
  "author": "mdzz-debug",
  "license": "MIT"
}
